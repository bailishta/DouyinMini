<?xml version="1.0" encoding="utf-8"?>
<com.douyinmini.ui.FullscreenVideoLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fullscreen_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="visible">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <android.webkit.WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="@color/douyin_red"
            android:visibility="gone"
            android:max="100" />

        <com.douyinmini.ui.ErrorOverlayView
            android:id="@+id/error_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:visibility="gone" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</com.douyinmini.ui.FullscreenVideoLayout>
